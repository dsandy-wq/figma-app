generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  approved      Boolean   @default(true)
  approvalToken String?   @unique
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

model Client {
  id            String         @id @default(cuid())
  name          String
  employer      String
  stage         String         @default("Initial Assessment")
  createdAt     DateTime       @default(now())
  interventions Intervention[]
}

model Intervention {
  id            String    @id @default(cuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type          String
  priority      Priority  @default(MEDIUM)
  assignedTo    String
  dueAt         DateTime
  status        String    @default("pending")
  deferredUntil DateTime?
  createdAt     DateTime  @default(now())
}
